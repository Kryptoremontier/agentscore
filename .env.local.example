# ============================================================================
# AgentScore — Local Environment Configuration
# ============================================================================
#
# Copy this file to .env.local and adjust the values to your needs.
# All variables prefixed with NEXT_PUBLIC_ are embedded at BUILD TIME
# and shipped to the browser.
#
# .env.local is gitignored — never commit it. Use this file as the reference.
# ============================================================================


# ── GraphQL / Network ────────────────────────────────────────────────────────

# Intuition Protocol GraphQL endpoint.
# Change this when switching networks (testnet → mainnet).
NEXT_PUBLIC_GRAPHQL_URL=https://testnet.intuition.sh/v1/graphql

# Human-readable tag shown in logs / admin UI. No functional effect.
NEXT_PUBLIC_PLATFORM_TAG=testnet


# ── Platform Label Prefixes (the "unique TAG" for your data) ─────────────────
#
# These prefixes are:
#   1. Prepended to atom labels when CREATING new Agents/Skills on-chain.
#   2. Used as GraphQL _ilike filters when READING data from the network.
#
# Changing these effectively creates a clean namespace for your platform's
# data, invisible to anyone using a different prefix.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SCENARIO                │ AGENT_PREFIX      │ SKILL_PREFIX            │
# ├─────────────────────────────────────────────────────────────────────────┤
# │  Current testnet         │ Agent:            │ Skill:                  │
# │  Alpha launch (fresh)    │ Agent:alpha:      │ Skill:alpha:            │
# │  Version 2               │ Agent:v2:         │ Skill:v2:               │
# │  Mainnet                 │ Agent:            │ Skill:                  │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ⚠️  Changing this on a LIVE deployment means existing data with the old
#     prefix will no longer appear in the platform UI. Only change when
#     migrating to a new network or intentionally starting a clean slate.
#
NEXT_PUBLIC_AGENT_PREFIX=Agent:
NEXT_PUBLIC_SKILL_PREFIX=Skill:


# ── App-Scoping ───────────────────────────────────────────────────────────────
#
# Controls whether the platform shows ONLY its own data or ALL Intuition data.
#
#   true  (default) — only show atoms/triples whose labels match the prefixes
#                     above. Hides data from other apps on the same network.
#
#   false           — show ALL atoms and triples on the Intuition network,
#                     regardless of creator or label format.
#                     Use this on mainnet when you want to discover community
#                     agents/skills that were created outside AgentScore.
#
NEXT_PUBLIC_APP_SCOPE=true


# ── Alpha / Fresh Testnet Date Filter ────────────────────────────────────────
#
# Optional ISO-8601 datetime. When set, ALL data queries add a
#   created_at >= ALPHA_DATE
# condition so you only see entities created after this point.
#
# Use case: you're migrating to a fresh testnet for alpha. Even if old testnet
# data somehow leaks into the new indexer, this filter ensures you see only
# freshly created content.
#
# Leave empty (or remove the line) to show all historical data.
#
# NEXT_PUBLIC_ALPHA_DATE=2025-06-01T00:00:00Z


# ── How to see ALL Intuition Protocol data (mainnet mode) ────────────────────
#
# To display every atom and triple on the network (useful on mainnet to
# discover community content not created via AgentScore):
#
#   NEXT_PUBLIC_APP_SCOPE=false
#
# To additionally remove the date filter:
#   # (leave NEXT_PUBLIC_ALPHA_DATE empty or commented out)
#
# To switch to mainnet GraphQL:
#   NEXT_PUBLIC_GRAPHQL_URL=https://prod.intuition.sh/v1/graphql   ← update once live


# ── WalletConnect ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id


# ── Optional Analytics ────────────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_MIXPANEL_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
