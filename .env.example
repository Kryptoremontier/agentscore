# ═══════════════════════════════════════════
# AgentScore — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Intuition Network ───────────────────────
# GraphQL endpoint (default: Intuition Testnet)
# NEXT_PUBLIC_GRAPHQL_URL=https://testnet.intuition.sh/v1/graphql

# ── Platform Scoping ────────────────────────
# Label prefixes for on-chain atoms (change to create a clean namespace)
# NEXT_PUBLIC_AGENT_PREFIX=Agent:
# NEXT_PUBLIC_SKILL_PREFIX=Skill:

# Show only AgentScore-created content (default: true)
# NEXT_PUBLIC_APP_SCOPE=true

# Optional: filter data created after this date (ISO-8601)
# NEXT_PUBLIC_ALPHA_DATE=2025-06-01T00:00:00Z

# ── Platform Identity Atoms ─────────────────
# Set these after first bootstrap to avoid on-chain lookup on every cold start
# NEXT_PUBLIC_AGENTSCORE_ATOM_ID=0x...
# NEXT_PUBLIC_CREATED_VIA_ATOM_ID=0x...

# ── Optional ────────────────────────────────
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# Set to 'true' to enable /test-intuition debug page (dev only)
NEXT_PUBLIC_ENABLE_TEST_PAGE=false
